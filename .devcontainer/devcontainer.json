{
  "name": "Microsoft Foundry Workshop",
  "workspaceFolder": "/workspaces/${localWorkspaceFolderBasename}",
  "image": "mcr.microsoft.com/devcontainers/python:3.12-bookworm",

  "privileged": true,

  "features": {
    "ghcr.io/devcontainers/features/common-utils:2": {
      "installZsh": true,
      "installOhMyZsh": true,
      "upgradePackages": true
    },
    "ghcr.io/devcontainers/features/git:1": {
      "version": "latest"
    },
    "ghcr.io/devcontainers/features/node:1": {
      "version": "lts"
    },
    "ghcr.io/devcontainers/features/docker-in-docker:2": {
      "version": "latest"
    },
    "ghcr.io/devcontainers/features/azure-cli:1": {
      "version": "latest",
      "extensions": "account"
    },
    "ghcr.io/devcontainers-extra/features/uv:1": {
      "version": "latest"
    }
  },

  "customizations": {
    "vscode": {
      // "extensions" for this project are specified in here will be installed in Dev Container.
      "extensions": [
        "bierner.markdown-mermaid",
        "esbenp.prettier-vscode",
        "GitHub.vscode-github-actions",
        "humao.rest-client",
        "ms-python.python",
        "ms-toolsai.jupyter",
        "ms-toolsai.jupyter-keymap",
        "ms-toolsai.jupyter-renderers",
        "ms-vscode.azurecli",
        "redhat.vscode-yaml",
        "tamasfe.even-better-toml"
      ]
      // "settings" for this project must be placed in infra/terraform/.vscode/settings.json.
      // DevContainer automatically inherits the workspace settings.json.
      // "settings": {}
    }
  },

  "postCreateCommand": "uv sync --extra dev && uv run poe setup && terraform version && az version",

  "remoteUser": "vscode",
  "mounts": [
    "source=${localEnv:HOME}${localEnv:USERPROFILE}/.azure,target=/home/vscode/.azure,type=bind,consistency=cached"
  ]
}
